APP_NAME="yt-downloader API"
APP_ENV="development"
HOST="127.0.0.1"
PORT="8080"
PROFILES_CONFIG_PATH="/etc/yt-downloader/profiles.json"
DATABASE_URL="mysql+pymysql://yt_downloader:change-me@127.0.0.1:3306/yt_downloader?charset=utf8mb4"
DATABASE_POOL_SIZE="5"
DATABASE_MAX_OVERFLOW="5"
DATABASE_POOL_RECYCLE_SECONDS="1800"
WORKER_ID="yt-downloader-worker-1"
WORKER_STALE_JOB_TIMEOUT_SECONDS="900"
WORKER_HEARTBEAT_INTERVAL_SECONDS="30"
DOWNLOAD_STAGING_ROOT="/var/lib/yt-downloader/staging"
DOWNLOAD_PROGRESS_UPDATE_INTERVAL_SECONDS="5"
DOWNLOAD_PROGRESS_MINIMUM_PERCENT_DELTA="1"
YT_DLP_MAX_ATTEMPTS="3"
YT_DLP_RETRY_INITIAL_DELAY_SECONDS="2"
SESSION_COOKIE_NAME="yt_downloader_session"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="lax"
SESSION_IDLE_TIMEOUT_SECONDS="43200"
SESSION_REMEMBER_ME_TIMEOUT_SECONDS="2592000"
SESSION_TOKEN_BYTES="32"
