music.alejandrogb.local {
    tls /etc/ssl/yt-downloader/music.alejandrogb.local.crt /etc/ssl/yt-downloader/music.alejandrogb.local.key

    encode zstd gzip

    root * /var/www/yt-downloader

    route {
        @api path /api/*
        handle @api {
            reverse_proxy 127.0.0.1:8080
        }

        handle {
            try_files {path} /index.html
            file_server
        }
    }
}
